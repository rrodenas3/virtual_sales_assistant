DATABASE_URL=sqlite+aiosqlite:///./phantom.db
APP_ENV=local
AUTO_CREATE_TABLES=true
ALLOWED_ORIGINS=["http://localhost:5173"]
OBSERVABILITY_PROVIDER=structured
TRACE_SAMPLE_RATE=1.0
AUTH_MODE=mock_jwt
AUTH_PROVIDER=mock
EXTERNAL_JWT_ISSUER=
EXTERNAL_JWT_AUDIENCE=
DISCOVERY_DATA_SHARING_MODEL=
DISCOVERY_CRM_PLATFORM=
DISCOVERY_ERP_SANDBOX=
DISCOVERY_PILOT_TERRITORY=WEST-01
DISCOVERY_REP_DEVICE=PWA
DISCOVERY_SSO_PROVIDER=
DISCOVERY_DATA_RESIDENCY=
DISCOVERY_OFFLINE_SYNC_POLICY=browser-feedback-queue
TERRITORY_TIMEZONE=Europe/Paris
OSA_SOURCE_SYSTEM=mock
OSA_MODEL_VERSION=mock-v1
OSA_ADAPTER=mock
RGM_ADAPTER=mock
STORE_MASTER_ADAPTER=mock
AUDIT_SINK=postgres
AGENT_GRAPH_ENABLED=false
AGENT_RUN_ENABLED=false
MEMORY_PROVIDER=none
MEM0_TOKEN_REF=
LLM_MODEL_ID=grounded-template-v1
