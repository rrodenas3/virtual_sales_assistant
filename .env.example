DATABASE_URL=sqlite+aiosqlite:///./phantom.db
APP_ENV=local
AUTO_CREATE_TABLES=true
ALLOWED_ORIGINS=["http://localhost:5173"]
OBSERVABILITY_PROVIDER=structured
TRACE_SAMPLE_RATE=1.0
AUTH_MODE=mock_jwt
AUTH_PROVIDER=mock
EXTERNAL_JWT_ISSUER=
EXTERNAL_JWT_AUDIENCE=
EXTERNAL_JWT_JWKS_URL=
EXTERNAL_JWT_ROLE_CLAIM=role
EXTERNAL_JWT_TERRITORY_CLAIM=territory_code
EXTERNAL_JWT_ALGORITHMS=["RS256"]
DISCOVERY_DATA_SHARING_MODEL=
DISCOVERY_CRM_PLATFORM=
DISCOVERY_ERP_SANDBOX=
DISCOVERY_PILOT_TERRITORY=WEST-01
DISCOVERY_REP_DEVICE=PWA
DISCOVERY_SSO_PROVIDER=
DISCOVERY_DATA_RESIDENCY=
DISCOVERY_OFFLINE_SYNC_POLICY=browser-feedback-queue
LIVE_DATA_CONTRACT_VALIDATED=false
LIVE_DATA_CONTRACT_LAST_VALIDATION_AT=
LIVE_DATA_CONTRACT_VALIDATION_SUMMARY=
TERRITORY_TIMEZONE=Europe/Paris
OSA_SOURCE_SYSTEM=mock
OSA_MODEL_VERSION=mock-v1
OSA_ADAPTER=mock
RGM_ADAPTER=mock
STORE_MASTER_ADAPTER=mock
AUDIT_SINK=postgres
AUDIT_DUAL_WRITE_ENABLED=false
AUDIT_DUAL_WRITE_FAIL_CLOSED=true
AUDIT_UNITY_CATALOG_TABLE=phantom.audit.agent_actions
GUARDRAIL_PROVIDER=pattern
GUARDRAIL_CLASSIFIER_ENDPOINT=
GUARDRAIL_CLASSIFIER_BLOCK_THRESHOLD=0.85
GUARDRAIL_CLASSIFIER_TIMEOUT_SECONDS=3
GUARDRAIL_FAIL_CLOSED=true
AGENT_GRAPH_ENABLED=false
AGENT_RUN_ENABLED=true
MEMORY_PROVIDER=none
MEM0_TOKEN_REF=
SUMMARY_PROVIDER=template
LLM_MODEL_ID=grounded-template-v1
ANTHROPIC_TOKEN_REF=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_TIMEOUT_SECONDS=8
ANTHROPIC_MAX_TOKENS=600
SUMMARY_FAIL_OPEN=false
VITE_API_URL=http://localhost:8000
VITE_AGENT_RUN_ENABLED=true
VITE_PWA_ENABLED=true
