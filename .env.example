DATABASE_URL=sqlite+aiosqlite:///./phantom.db
APP_ENV=local
AUTO_CREATE_TABLES=true
ALLOWED_ORIGINS=["http://localhost:5173"]
AUTH_MODE=mock_jwt
AUTH_PROVIDER=mock
EXTERNAL_JWT_ISSUER=
EXTERNAL_JWT_AUDIENCE=
TERRITORY_TIMEZONE=Europe/Paris
OSA_SOURCE_SYSTEM=mock
OSA_MODEL_VERSION=mock-v1
OSA_ADAPTER=mock
RGM_ADAPTER=mock
STORE_MASTER_ADAPTER=mock
AUDIT_SINK=postgres
AGENT_GRAPH_ENABLED=false
LLM_MODEL_ID=grounded-template-v1
VITE_API_URL=http://localhost:8000
